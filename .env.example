# Copie este arquivo para ".env" e preencha com as chaves do SEU projeto
# Firebase (Console do Firebase > Configurações do projeto > Seus apps > SDK).
#
# IMPORTANTE: variáveis com prefixo EXPO_PUBLIC_ ficam embutidas no bundle
# do app (é assim que o Expo expõe variáveis de ambiente ao código do
# cliente). A apiKey do Firebase Web/JS SDK NÃO é secreta por natureza —
# quem protege os dados são as Regras de Segurança do Firestore/Auth,
# não o sigilo dessa chave. Mesmo assim, não commite o arquivo ".env"
# real (ele já está no .gitignore).

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
